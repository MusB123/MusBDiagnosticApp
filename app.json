{
  "expo": {
    "name": "MusBDiagnostics",
    "slug": "MusBDiagnostics",
    "scheme": "musbdiagnostics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1F5C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.musb.diagnostics"
    },
    "android": {
      "package": "com.musb.diagnostics",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.musbdiagnostics"
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "fd2fae81-138e-4df4-ab5a-494a1a89d405"
      }
    },
    "owner": "ins_lu3fer"
  }
}
